{
  "_comment": "Example openclaw.json showing SecretRef objects for 8 common credentials. Adapt vault/item names to match your 1Password setup.",

  "secrets": {
    "providers": {
      "onepassword": {
        "source": "exec",
        "command": "/Users/YOUR_USERNAME/.openclaw/bin/op-resolver.sh",
        "allowSymlinkCommand": false,
        "trustedDirs": ["/Users/YOUR_USERNAME/.openclaw/bin"],
        "passEnv": ["HOME"],
        "jsonOnly": true,
        "timeoutMs": 15000
      }
    }
  },

  "agents": {
    "defaults": {
      "memorySearch": {
        "remote": {
          "apiKey": {
            "source": "exec",
            "provider": "onepassword",
            "id": "op://OpenClaw Secrets/openclaw-voyage/credential"
          }
        }
      }
    }
  },

  "channels": {
    "bluebubbles": {
      "password": {
        "source": "exec",
        "provider": "onepassword",
        "id": "op://OpenClaw Secrets/openclaw-bluebubbles/credential"
      }
    },
    "discord": {
      "token": {
        "source": "exec",
        "provider": "onepassword",
        "id": "op://OpenClaw Secrets/openclaw-discord/credential"
      }
    }
  },

  "gateway": {
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}",
      "_note": "gateway.auth.token does NOT support SecretRef. Resolved by launch-gateway.sh."
    }
  },

  "messages": {
    "tts": {
      "openai": {
        "apiKey": {
          "source": "exec",
          "provider": "onepassword",
          "id": "op://OpenClaw Secrets/openclaw-openai-tts/credential"
        }
      }
    }
  },

  "skills": {
    "entries": {
      "goplaces": {
        "apiKey": {
          "source": "exec",
          "provider": "onepassword",
          "id": "op://OpenClaw Secrets/openclaw-google-places/credential"
        }
      }
    }
  },

  "talk": {
    "apiKey": {
      "source": "exec",
      "provider": "onepassword",
      "id": "op://OpenClaw Secrets/openclaw-elevenlabs/credential"
    }
  },

  "tools": {
    "web": {
      "search": {
        "apiKey": {
          "source": "exec",
          "provider": "onepassword",
          "id": "op://OpenClaw Secrets/openclaw-brave-search/credential"
        }
      }
    }
  }
}
